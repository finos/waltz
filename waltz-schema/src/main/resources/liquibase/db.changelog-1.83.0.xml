<databaseChangeLog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.4.xsd"
                   logicalFilePath="db.changelog-1.83.0.xml">

    <changeSet id="v1-82-0-tag"
               author="ramerav">
        <tagDatabase tag="v1.82.0"/> <!-- tag the current db version, i.e. the last  -->
    </changeSet>

    <changeSet id="20260512-7523-1" author="jainkhu">
        <insert tableName="settings">
            <column name="name" value="feature.data-flows-timeout-threshold"/>
            <column name="value" value="30"/>
            <column name="description" value="This specifies the threshold for days after which pending flows will time out."/>
            <column name="restricted" valueBoolean="false"/>
        </insert>
    </changeSet>
</databaseChangeLog>